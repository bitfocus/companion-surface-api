{
    "name": "@companion-surface/api",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "run build:schema && run build:root",
        "build:clean": "(rm -rf ./packages/*/dist ./packages/*/generated ./packages/*/*.tsbuildinfo || true) && run build",
        "build:root": "tsc --build tsconfig.build.json",
        "build:schema": "cd packages/base && node ./tools/schema-compile.mjs",
        "dev": "run build:root --watch",
        "lint": "eslint .",
        "unit": "vitest run",
        "unit:watch": "vitest"
    },
    "engines": {
        "node": "^22.21"
    },
    "devDependencies": {
        "@companion-module/tools": "^3.0.2",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^22.20.1",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "json-schema-to-typescript": "^15.0.4",
        "prettier": "^3.9.4",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.1.10",
        "vitest-mock-extended": "^4.0.0",
        "zx": "^8.8.5"
    },
    "packageManager": "yarn@4.17.1"
}
